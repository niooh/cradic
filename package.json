{
  "name": "cradic",
  "version": "0.0.5",
  "type": "module",
  "description": "Deconstruct Chinese characters into radicals and reassemble them for intriguing visual effects",
  "repository": {
    "type": "git",
    "url": "https://github.com/niooh/cradic"
  },
  "main": "dist/cradic.cjs",
  "module": "dist/cradic.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "chmod +x .githooks/* 2>/dev/null; git config core.hooksPath .githooks || true",
    "build:node": "rollup -c rollup.config.ts",
    "build:browser": "vite build",
    "build": "npm run build:browser && npm run build:node",
    "prepublishOnly": "npm run check && rm -rf dist/tmp && npm run build",
    "dev": "vite",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "demo": "node tests/demos/demo1.js && node tests/demos/demo2.js"
  },
  "exports": {
    ".": {
      "node": {
        "import": "./dist/cradic.esm.js",
        "require": "./dist/cradic.cjs"
      },
      "browser": "./dist/cradic.browser.js"
    }
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^25.6.0",
    "rollup": "^4.0.0",
    "rollup-plugin-oxc": "^0.7.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "chinese",
    "character",
    "radical",
    "deconstruct",
    "reassemble",
    "visualization",
    "split",
    "typography",
    "拆字"
  ],
  "author": "niooh",
  "license": "MIT"
}
