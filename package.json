{
  "name": "cradic",
  "version": "0.0.2",
  "type": "module",
  "description": "Deconstruct Chinese characters into radicals and reassemble them for intriguing visual effects",
  "repository": {
    "type": "git",
    "url": "https://github.com/ldlsn1/cradic"
  },
  "main": "dist/cradic.cjs",
  "module": "dist/cradic.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:node": "rollup -c rollup.config.js",
    "build:browser": "vite build",
    "build": "npm run build:browser && npm run build:node",
    "prepublishOnly": "rm -rf dist/tmp && npm run build",
    "dev": "vite",
    "test": "node tests/test.js",
    "demo": "node tests/demo1.js && node tests/demo2.js"
  },
  "exports": {
    ".": {
      "node": {
        "import": "./dist/cradic.esm.js",
        "require": "./dist/cradic.cjs"
      },
      "browser": "./dist/cradic.browser.js"
    }
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^25.6.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "keywords": [ "chinese", "character", "radical", "deconstruct", "reassemble", "visualization", "split", "typography" ],
  "author": "ldlsn1",
  "license": "MIT"
}
