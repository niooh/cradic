#!/usr/bin/env node
import { readFileSync } from 'fs';

const msgFile = process.argv[2];
const msg = readFileSync(msgFile, 'utf8').trim();

const pattern = /^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?!?: .+/;

if (!pattern.test(msg)) {
  console.error('\x1b[31mERROR: Commit message does not follow Conventional Commits format.\x1b[0m');
  console.error('Expected format: `<type>(<scope>): <subject>`');
  console.error('Example: `fix: resolve login timeout issue`');
  process.exit(1);
}
